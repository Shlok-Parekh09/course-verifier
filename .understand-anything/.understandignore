# .understandignore — patterns for files/dirs to exclude from analysis
# Syntax: same as .gitignore (globs, # comments, ! negation, trailing / for dirs)
# Lines below are suggestions — uncomment to activate.
# Use ! prefix to force-include something excluded by defaults.
#
# Built-in defaults (always excluded unless negated):
#   node_modules/, .git/, dist/, build/, obj/, *.lock, *.min.js, etc.
#

# --- Secrets & credentials ---
.env
serviceAccountKey.json
mongo_uri.txt

# --- Browser profiles (Chrome persistent sessions) ---
chrome_profile/
chrome_profile_*/
chrome_profile_fallback/
chrome_profile_fallback_*/

# --- Screenshots & run artifacts ---
verification_screenshots/
worker/.wrangler/

# --- Input / report PDFs (large, not source code) ---
*.pdf

# --- Excel data files ---
*.xlsx

# --- Runtime JSON data dumps (generated by the verifier) ---
*_floating_items.json
master_dashboard_results.json
old_status_mapping.json
committed_courses_backup.json
autonomous_verified_*.json
api_check_report.json
coursera_cookies.json

# --- Kept (reference data loaded by code) ---
# affiliation_db.json, university_abbreviations.json, rankings.db remain included.

# --- Test file patterns (uncomment to exclude) ---

# JS / TS
# *.test.*
# *.spec.*
# *.snap
# C# / .NET
# **/*Tests.cs
# **/*Test.cs
# **/*Fixture.cs
# **/*.Tests.csproj
# Java / Kotlin
# **/src/test/**
# **/*Test.java
# **/*IT.java
# **/*Spec.kt
# Go
# **/*_test.go