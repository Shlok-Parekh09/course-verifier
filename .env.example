# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# ── Coursera Credentials ──────────────────────────────────────────────────────
COURSERA_EMAIL=your_email@example.com
COURSERA_PASSWORD=your_coursera_password

# ── General Bot Credentials ───────────────────────────────────────────────────
MY_EMAIL=your_email@example.com
MY_PASSWORD=your_password
NDU_PASSWORD=your_ndu_password
FORM_NAME=Your Full Name
FORM_PHONE=+91XXXXXXXXXX
FORM_EMAIL=your_email@example.com

# ── Text Generation API Keys (Gemini) ────────────────────────────────────────
GEMINI_KEY_1=your_gemini_key_1
GEMINI_KEY_2=your_gemini_key_2
GEMINI_KEY_3=your_gemini_key_3
GEMINI_KEY_4=your_gemini_key_4
GEMINI_KEY_5=your_gemini_key_5
GEMINI_KEY_6=your_gemini_key_6

# ── Text Generation API Keys (NVIDIA) ────────────────────────────────────────
NVIDIA_KEY_1=your_nvidia_key_1
NVIDIA_KEY_2=your_nvidia_key_2
NVIDIA_KEY_3=your_nvidia_key_3
NVIDIA_KEY_4=your_nvidia_key_4
NVIDIA_KEY_5=your_nvidia_key_5
NVIDIA_KEY_6=your_nvidia_key_6

# ── Text Generation API Keys (OpenRouter) ────────────────────────────────────
OPENROUTER_KEY_1=your_openrouter_key_1
OPENROUTER_KEY_2=your_openrouter_key_2
OPENROUTER_KEY_3=your_openrouter_key_3
OPENROUTER_KEY_4=your_openrouter_key_4
OPENROUTER_KEY_5=your_openrouter_key_5
OPENROUTER_KEY_6=your_openrouter_key_6

# ── Vision API Keys (Groq) ────────────────────────────────────────────────────
GROQ_API_KEY_1=your_groq_key_1
GROQ_API_KEY_2=your_groq_key_2
GROQ_API_KEY_3=your_groq_key_3
GROQ_API_KEY_4=your_groq_key_4
GROQ_API_KEY_5=your_groq_key_5
GROQ_API_KEY_6=your_groq_key_6

# ── Vision API Keys (Mistral) ─────────────────────────────────────────────────
MISTRAL_API_KEY_1=your_mistral_key_1
MISTRAL_API_KEY_2=your_mistral_key_2
MISTRAL_API_KEY_3=your_mistral_key_3
MISTRAL_API_KEY_4=your_mistral_key_4
MISTRAL_API_KEY_5=your_mistral_key_5
MISTRAL_API_KEY_6=your_mistral_key_6

# ── Vision API Keys (SambaNova) ───────────────────────────────────────────────
SAMBANOVA_API_KEY_1=your_sambanova_key_1
SAMBANOVA_API_KEY_2=your_sambanova_key_2
SAMBANOVA_API_KEY_3=your_sambanova_key_3
SAMBANOVA_API_KEY_4=your_sambanova_key_4
SAMBANOVA_API_KEY_5=your_sambanova_key_5
SAMBANOVA_API_KEY_6=your_sambanova_key_6

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=nemotron-3-super:cloud
OLLAMA_API_KEY=

# ── Optional: Auto-deploy to Firebase Hosting after PDF upload ────────────────
# Set to true to automatically run "firebase deploy --only hosting" after uploads
AUTO_DEPLOY=false
